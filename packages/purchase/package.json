{
  "name": "@shware/purchase",
  "version": "4.0.3",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShwareHQ/shware-sdk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./app-store": {
      "import": {
        "types": "./dist/app-store/index.d.mts",
        "default": "./dist/app-store/index.mjs"
      },
      "require": {
        "types": "./dist/app-store/index.d.cts",
        "default": "./dist/app-store/index.cjs"
      }
    },
    "./google-play": {
      "import": {
        "types": "./dist/google-play/index.d.mts",
        "default": "./dist/google-play/index.mjs"
      },
      "require": {
        "types": "./dist/google-play/index.d.cts",
        "default": "./dist/google-play/index.cjs"
      }
    },
    "./stripe": {
      "import": {
        "types": "./dist/stripe/index.d.mts",
        "default": "./dist/stripe/index.mjs"
      },
      "require": {
        "types": "./dist/stripe/index.d.cts",
        "default": "./dist/stripe/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsdown",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --type-aware . --fix"
  },
  "dependencies": {
    "@shware/utils": "workspace:^",
    "@types/ms": "^2.1.0",
    "ms": "^2.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "stripe": "^22.3.2"
  },
  "peerDependenciesMeta": {
    "@apple/app-store-server-library": {
      "optional": true
    },
    "stripe": {
      "optional": true
    }
  }
}
