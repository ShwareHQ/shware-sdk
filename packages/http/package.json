{
  "name": "@shware/http",
  "version": "3.0.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShwareHQ/shware-sdk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./polyfills": {
      "import": {
        "types": "./dist/polyfills/index.d.mts",
        "default": "./dist/polyfills/index.mjs"
      },
      "require": {
        "types": "./dist/polyfills/index.d.cts",
        "default": "./dist/polyfills/index.cjs"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/hono/index.d.mts",
        "default": "./dist/hono/index.mjs"
      },
      "require": {
        "types": "./dist/hono/index.d.cts",
        "default": "./dist/hono/index.cjs"
      }
    },
    "./webhook": {
      "import": {
        "types": "./dist/webhook/index.d.mts",
        "default": "./dist/webhook/index.mjs"
      },
      "require": {
        "types": "./dist/webhook/index.d.cts",
        "default": "./dist/webhook/index.cjs"
      }
    },
    "./google-one-tap": {
      "import": {
        "types": "./dist/google-one-tap/index.d.mts",
        "default": "./dist/google-one-tap/index.mjs"
      },
      "require": {
        "types": "./dist/google-one-tap/index.d.cts",
        "default": "./dist/google-one-tap/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsdown",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --type-aware . --fix"
  },
  "dependencies": {
    "@shware/utils": "workspace:^",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "hono": "^4.12.29",
    "i18next": "^26.3.6",
    "react": "^19.2.7"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "i18next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
