{
  "name": "@shware/security",
  "version": "2.5.3",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShwareHQ/shware-sdk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./oauth2/provider": {
      "import": {
        "types": "./dist/oauth2/provider/index.d.ts",
        "default": "./dist/oauth2/provider/index.mjs"
      },
      "require": {
        "types": "./dist/oauth2/provider/index.d.cts",
        "default": "./dist/oauth2/provider/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsdown",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --type-aware src --fix"
  },
  "dependencies": {
    "@shware/utils": "workspace:^",
    "cookie": "^2.0.1",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "path-to-regexp": "^8.4.2",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "ts-node": "^10.9.2",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
