{
  "name": "@shware/security",
  "version": "2.5.1",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShwareHQ/shware-sdk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./oauth2/provider": {
      "types": "./dist/oauth2/provider/index.d.ts",
      "import": "./dist/oauth2/provider/index.mjs",
      "require": "./dist/oauth2/provider/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsup",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "lint": "oxlint src --fix"
  },
  "dependencies": {
    "@shware/utils": "workspace:^",
    "cookie": "^1.1.1",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "path-to-regexp": "^8.4.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.3",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
