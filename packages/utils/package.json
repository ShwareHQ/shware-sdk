{
  "name": "@shware/utils",
  "version": "1.5.1",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShwareHQ/shware-sdk.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsdown",
    "test": "vitest run",
    "check-types": "tsc --noEmit",
    "lint": "oxlint --type-aware src --fix"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "^19.2.8"
  },
  "peerDependenciesMeta": {}
}
